{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-debug",
            "type": "shell",
            "command": "${config:clangPath}",
            "args": [
                "-g",
                "-O0",
                "-o",
                "build/debug/${config:outputFile}",
                "main_Accepted.cpp"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Build debug version"
        },
        {
            "label": "build-release",
            "type": "shell",
            "command": "${config:clangPath}",
            "args": [
                "-O2",
                "-o",
                "build/release/${config:outputFile}",
                "main_Accepted.cpp"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Build release version"
        }
    ]
}